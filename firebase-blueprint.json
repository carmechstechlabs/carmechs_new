{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a car owner, mechanic, or admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "mechanic", "admin", "workshop_owner", "viewer"] },
        "avatar": { "type": "string" },
        "verified": { "type": "boolean" },
        "blocked": { "type": "boolean" },
        "walletBalance": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralsCount": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle owned by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "string" },
        "fuelType": { "type": "string" },
        "licensePlate": { "type": "string" },
        "vin": { "type": "string" },
        "lastServiceDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "make", "model", "year", "fuelType"]
    },
    "Workshop": {
      "title": "Workshop",
      "description": "A service workshop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "servicesOffered": { "type": "array", "items": { "type": "string" } },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "ownerId": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Service": {
      "title": "Service",
      "description": "A maintenance or repair service offered.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "commonIssues": { "type": "array", "items": { "type": "string" } },
        "recommendedCheckups": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "description", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "A category of services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "icon"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A service request from an owner to a mechanic.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "mechanicId": { "type": "string" },
        "serviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed", "cancelled"] },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["ownerId", "serviceId", "status", "date", "time"]
    },
    "Technician": {
      "title": "Technician",
      "description": "A mechanic profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "servicesOffered": { "type": "array", "items": { "type": "string" } },
        "availability": { "type": "string" },
        "serviceArea": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "busy", "off"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      },
      "required": ["id", "userId", "name", "specialty"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a service or mechanic.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "serviceId": { "type": "string" },
        "technicianId": { "type": "string" },
        "createdAt": { "type": "string" },
        "isPublished": { "type": "boolean" }
      },
      "required": ["userId", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for owners and mechanics."
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "User vehicles."
    },
    "/workshops/{workshopId}": {
      "schema": "Workshop",
      "description": "Service workshops."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Catalog of available services."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Service categories."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service booking records."
    },
    "/technicians/{technicianId}": {
      "schema": "Technician",
      "description": "Mechanic profiles."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Service and mechanic reviews."
    }
  }
}
